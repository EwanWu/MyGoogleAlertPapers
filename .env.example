# IMAP settings
# Optional: if omitted, the app can fall back to ~/.config/imap-smtp-email/.env
# Optional account selector for multi-account skill config, e.g. IMAP_ACCOUNT=gmail
IMAP_ACCOUNT=
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# Local paths
SQLITE_PATH=data/mgap.db
LOG_LEVEL=INFO

# Optional scholarly API settings for later phases
OPENALEX_EMAIL=
CROSSREF_MAILTO=
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
